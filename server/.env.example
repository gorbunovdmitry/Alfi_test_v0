# Copy to server/.env ON THE SERVER (do NOT commit). Values below are placeholders.
AITUNNEL_API_KEY=
AITUNNEL_MODEL=gpt-5.4-nano

# DuckDNS subdomain that points to the server IP, e.g. alfi-demo.duckdns.org
ALFI_DOMAIN=
# DuckDNS token (from duckdns.org)
DUCKDNS_TOKEN=

# Origin allowed by CORS — the GitHub Pages site
ALLOWED_ORIGIN=https://gorbunovdmitry.github.io
